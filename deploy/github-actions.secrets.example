# Copy to deploy/github-actions.secrets and fill in (never commit that file).
# Use the SAME VPS + GHCR values as city-airport-taxis-backend.

DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_SSH_KEY_FILE=
GHCR_TOKEN=

DEPLOY_PATH=/opt/city-airport-taxis-admin
DEPLOY_PORT_APP=3000

NEXT_PUBLIC_BACKEND_URL=https://api.city-airport-taxis.be/api
NEXT_PUBLIC_SITE_URL=https://admin.city-airport-taxis.be
NEXT_PUBLIC_SOCKET_PATH=/socket.io
